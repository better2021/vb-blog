<%- include('../partials/head', { title, description, currentPath }) %>

<section class="page-heading admin-heading">
  <p class="eyebrow">后台</p>
  <h1>Markdown 文章</h1>
  <p>创建、编辑、上传和删除 Markdown / HTML 文章。</p>
  <div class="admin-actions">
    <a class="button-link" href="/admin/posts/new">新建文章</a>
    <a class="button-link" href="/admin/upload">上传文件</a>
  </div>
</section>

<% if (message) { %>
  <div class="notice success"><%= message %></div>
<% } %>

<% if (error) { %>
  <div class="notice error"><%= error %></div>
<% } %>

<section class="admin-list" aria-label="后台文章列表">
  <% posts.forEach((post) => { %>
    <article class="admin-row">
      <div>
        <div class="post-meta">
          <time datetime="<%= post.date %>"><%= post.date %></time>
          <span><%= post.category %></span>
        </div>
        <h2><a href="/posts/<%= post.slug %>"><%= post.title %></a></h2>
        <p><code><%= post.fileName %></code></p>
      </div>
      <div class="admin-row-actions">
        <a class="button-link" href="/admin/posts/<%= post.slug %>/edit">编辑</a>
        <form class="delete-post-form" action="/admin/posts/<%= post.slug %>/delete" method="post" data-post-title="<%= post.title %>">
          <button class="danger-button" type="submit">删除</button>
        </form>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>
