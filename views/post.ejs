<%- include('partials/head', { title, description, currentPath }) %>

<article class="article-page">
  <a class="text-link" href="/">返回首页</a>
  <header class="article-header">
    <div class="post-meta">
      <time datetime="<%= post.date %>"><%= post.date %></time>
      <a href="/categories/<%= encodeURIComponent(post.category) %>"><%= post.category %></a>
    </div>
    <h1><%= post.title %></h1>
    <p><%= post.excerpt %></p>
    <div class="tag-row">
      <% post.tags.forEach((tag) => { %>
        <a href="/tags/<%= encodeURIComponent(tag) %>">#<%= tag %></a>
      <% }) %>
    </div>
  </header>
  <div class="article-content markdown-body">
    <%- post.html %>
  </div>
</article>

<%- include('partials/footer') %>
