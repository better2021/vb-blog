<%- include('partials/head', { title, description, currentPath }) %>

<section class="hero">
  <p class="eyebrow">Markdown 博客</p>
  <h1>技术文章与个人笔记</h1>
  <p>一个使用本地 Markdown 文件驱动的干净服务端渲染博客。</p>
</section>

<div class="content-grid">
  <section class="content-main" aria-label="文章列表">
    <div class="toolbar">
      <form class="search-form" action="/" method="get">
        <label for="search">搜索文章</label>
        <div class="search-row">
          <input id="search" name="q" type="search" maxlength="80" value="<%= searchQuery %>" placeholder="搜索标题、标签或正文">
          <input type="hidden" name="view" value="<%= viewMode %>">
          <button type="submit">搜索</button>
        </div>
      </form>
      <div class="view-switcher" aria-label="视图切换">
        <a class="<%= viewMode === 'card' ? 'active' : '' %>" href="/?q=<%= encodeURIComponent(searchQuery) %>&view=card">卡片</a>
        <a class="<%= viewMode === 'list' ? 'active' : '' %>" href="/?q=<%= encodeURIComponent(searchQuery) %>&view=list">列表</a>
      </div>
    </div>

    <% if (posts.length > 0) { %>
      <%- include('partials/post-list', { posts, viewMode }) %>
    <% } else { %>
      <div class="empty-state">
        <h2>没有找到相关文章</h2>
        <p>换一个关键词试试，或返回首页浏览全部文章。</p>
        <a class="text-link" href="/">返回首页</a>
      </div>
    <% } %>

    <nav class="pagination" aria-label="分页">
      <% if (pagination.hasPreviousPage) { %>
        <a href="/?page=<%= pagination.currentPage - 1 %>&q=<%= encodeURIComponent(searchQuery) %>&view=<%= viewMode %>">上一页</a>
      <% } else { %>
        <span>上一页</span>
      <% } %>
      <strong>第 <%= pagination.currentPage %> / <%= pagination.totalPages %> 页</strong>
      <% if (pagination.hasNextPage) { %>
        <a href="/?page=<%= pagination.currentPage + 1 %>&q=<%= encodeURIComponent(searchQuery) %>&view=<%= viewMode %>">下一页</a>
      <% } else { %>
        <span>下一页</span>
      <% } %>
    </nav>
  </section>

  <%- include('partials/sidebar', { categories, tags }) %>
</div>

<%- include('partials/footer') %>
